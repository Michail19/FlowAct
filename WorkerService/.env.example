# ======================
# CORE
# ======================
SPRING_PROFILES_ACTIVE=init
SERVER_PORT=8082

# ======================
# DATABASE
# ======================
DB_URL=jdbc:postgresql://localhost:5432/flowact_execution
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ======================
# SERVICES
# ======================
AUTH_SERVICE_URL=http://localhost:8083
ML_SERVICE_URL=http://localhost:8000
GATEWAY_SERVICE_URL=http://localhost:8080
SCHEDULE_SERVICE_URL=http://localhost:8084

# ======================
# OPENAPI
# ======================
OPENAPI_ENABLED=true
SWAGGER_UI_ENABLED=true

# ======================
# LOGGING
# ======================
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_WEB=DEBUG
LOG_LEVEL_SQL=DEBUG
LOG_LEVEL_BIND=TRACE
LOG_LEVEL_APP=DEBUG

# ======================
# HEALTH
# ======================
HEALTH_DETAILS=always

# ======================
# HTTP
# ======================
HTTP_CONNECT_TIMEOUT=5000
HTTP_READ_TIMEOUT=15000

# ======================
# EXECUTION
# ======================
EXECUTION_MAX_DEPTH=100
EXECUTION_DEFAULT_PAGE_SIZE=20
EXECUTION_MAX_PAGE_SIZE=100

JPA_SHOW_SQL=true

# ======================
# KAFKA
# ======================

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
FLOWACT_KAFKA_EXECUTION_RUN_REQUESTED_TOPIC=flowact.execution.run.requested
