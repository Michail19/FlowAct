# Optional. Use init for demo data, prod for a cleaner startup without SQL seed data.
SPRING_PROFILES_ACTIVE=prod

# Optional external services if/when they are added.
AUTH_SERVICE_URL=http://host.docker.internal:8083
ML_SERVICE_URL=http://host.docker.internal:8000
SCHEDULE_SERVICE_URL=http://host.docker.internal:8084
FLOWACT_ML_BASE_URL=http://host.docker.internal:8000

# Optional OpenRouter settings for WorkerService LLM blocks.
# Keep default model as openrouter/free or use a concrete model id ending with :free
# to avoid paid OpenRouter usage during development.
FLOWACT_LLM_OPENROUTER_API_KEY=
FLOWACT_LLM_OPENROUTER_DEFAULT_MODEL=openrouter/free
FLOWACT_LLM_OPENROUTER_ALLOW_PAID_MODELS=false
FLOWACT_LLM_OPENROUTER_SITE_URL=http://localhost:3000
FLOWACT_LLM_OPENROUTER_APP_NAME=FlowAct
